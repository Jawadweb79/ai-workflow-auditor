# Copy this file to secrets.toml for local use
# On Streamlit Cloud, paste these values in the Secrets dashboard

DEEPSEEK_API_KEY = "sk-your-key-here"
GOOGLE_SHEET_NAME = "AI Workflow Auditor Leads"

# Paste the FULL contents of your credentials.json here:
[gcp_service_account]
type = "service_account"
project_id = "ai-workflow-auditor"
private_key_id = "your-key-id"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "ai-workflow-auditor@ai-workflow-auditor.iam.gserviceaccount.com"
client_id = "your-client-id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
